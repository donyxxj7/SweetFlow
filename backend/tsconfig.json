{
  "compilerOptions": {
    // Layout de Arquivos e Organização de Compilação
    "rootDir": ".",
    "outDir": "./dist",

    // Configurações do Ambiente de Execução do Node Moderno
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],

    // CORREÇÃO: Habilita os tipos do Node globalmente para reconhecer o 'process'
    "types": ["node"],

    // Geração de Mapas e Declarações (Ótimo para Debug e Portabilidade)
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Checagens Rígidas de Segurança (Qualidade Sênior de Código)
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    // Compatibilidade e Otimização do Compilador
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force"
  },
  // CORREÇÃO: Adicionado o drizzle.config.ts explicitamente para o TS ler a raiz
  "include": ["src/**/*", "drizzle.config.ts"],
  "exclude": ["node_modules", "dist"]
}
